{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "ignorePatterns": [
        "**/dist",
        "**/build",
        "**/docs",
        "**/.tsbuildinfo",
        ".agents/**/*",
        "**/index.ts",
        "repos/**",
        "**/CHANGELOG.md",
        "submodules/**",
        "!src/internal/generated/index.ts"
    ],
    "sortPackageJson": true,
    "trailingComma": "es5",
    "sortImports": {
        "newlinesBetween": true,
        "sortSideEffects": true,
        "internalPattern": ["./", "~/", "@/"],
        "groups": [
            "side_effect",
            "effect-types",
            "effect",
            "builtin",
            ["type-external", "type-parent", "type-sibling", "type-index"],
            "external",
            ["internal", "subpath"],
            ["value-parent", "value-sibling", "value-index"],
            "unknown"
        ],
        "customGroups": [
            {
                "selector": "type",
                "groupName": "effect-types",
                "elementNamePattern": ["effect", "effect/**"]
            },
            {
                "groupName": "effect",
                "elementNamePattern": ["effect", "effect/**"]
            }
        ]
    }
}
