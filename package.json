{
    "name": "the-moby-effect",
    "version": "1.51.7",
    "description": "Moby/Docker API client built using effect-ts",
    "keywords": [
        "docker",
        "effect-ts",
        "moby",
        "podman"
    ],
    "homepage": "https://github.com/leonitousconforti/the-moby-effect",
    "bugs": {
        "url": "https://github.com/leonitousconforti/the-moby-effect/issues",
        "email": "leo@leoconforti.us"
    },
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/leonitousconforti/the-moby-effect.git"
    },
    "files": [
        "src/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        "./package.json": "./package.json",
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./internal/*": null
    },
    "publishConfig": {
        "exports": {
            "./package.json": "./package.json",
            ".": "./dist/index.js",
            "./*": "./dist/*.js",
            "./internal/*": null
        },
        "access": "public"
    },
    "scripts": {
        "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
        "build": "tsc -b tsconfig.build.json && pnpm babel",
        "check": "tsc -b tsconfig.json",
        "circular": "madge --circular src/*.ts",
        "clean": "rimraf .tsbuildinfo docs build dist coverage",
        "codegen": "build-utils prepare-v4",
        "coverage": "vitest --coverage",
        "lint": "oxlint --disable-nested-config && oxfmt --check !repos/** !submodules/**",
        "lint-fix": "oxlint --disable-nested-config --fix && oxfmt --write !repos/** !submodules/**",
        "prepare": "effect-language-service patch",
        "schemagen": "cd reflection && go build && ./reflection",
        "test": "vitest",
        "update-blobs": "tsx ./scripts/update-blobs.ts",
        "changeset-version": "changeset version",
        "changeset-publish": "pnpm build && changeset publish"
    },
    "dependencies": {
        "effect-schemas": "0.0.15",
        "eftar": "0.0.76"
    },
    "devDependencies": {
        "@babel/cli": "7.28.6",
        "@babel/core": "7.28.6",
        "@changesets/cli": "2.31.1",
        "@effect/build-utils": "0.8.9",
        "@effect/docgen": "https://pkg.pr.new/Effect-TS/docgen/@effect/docgen@57ff897",
        "@effect/language-service": "0.64.1",
        "@effect/platform-browser": "4.0.0-beta.98",
        "@effect/platform-bun": "4.0.0-beta.98",
        "@effect/platform-node": "4.0.0-beta.98",
        "@effect/vitest": "4.0.0-beta.98",
        "@types/node": "25.0.6",
        "@types/ssh2": "1.15.5",
        "@types/ws": "8.18.1",
        "@vitest/coverage-v8": "3.2.4",
        "ast-types": "0.14.2",
        "babel-plugin-annotate-pure-calls": "0.5.0",
        "changesets-gitlab": "0.13.4",
        "effect": "4.0.0-beta.98",
        "glob": "13.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.53.0",
        "oxlint": "1.68.0",
        "rimraf": "6.1.2",
        "ssh2": "1.17.0",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "undici": "7.18.2",
        "vite": "7.3.1",
        "vite-tsconfig-paths": "6.0.4",
        "vitest": "3.2.4",
        "ws": "8.19.0"
    },
    "peerDependencies": {
        "@effect/platform-browser": "4.0.0-beta.98",
        "@effect/platform-bun": "4.0.0-beta.98",
        "@effect/platform-node": "4.0.0-beta.98",
        "effect": "4.0.0-beta.98"
    },
    "peerDependenciesMeta": {
        "@effect/platform-browser": {
            "optional": true
        },
        "@effect/platform-bun": {
            "optional": true
        },
        "@effect/platform-node": {
            "optional": true
        }
    },
    "optionalDependencies": {
        "ssh2": "^1.17.0",
        "undici": "^7.28.0",
        "ws": "^8.21.1"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
    "tags": [
        "moby",
        "docker",
        "podman",
        "effect-ts"
    ]
}
