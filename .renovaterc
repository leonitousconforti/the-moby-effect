{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended", ":dependencyDashboard", "helpers:pinGitHubActionDigests"],
    "labels": ["dependencies", "renovate"],
    "ignorePaths": ["**/node_modules/**", "repos/effect/**", "repos/effect-smol/**"],
    "enabledManagers": ["github-actions", "nix", "git-submodules", "pip_requirements", "npm"],
    "git-submodules": {
        "enabled": true
    },
    "nix": {
        "enabled": true
    },
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": ["before 5am on monday"],
        "commitMessageAction": "Refresh",
        "addLabels": ["lockfile-maintenance"]
    },
    "packageRules": [
        {
            "matchManagers": ["npm"],
            "enabled": false
        },
        {
            "description": "Pin GitHub Actions to a full commit SHA and keep that SHA at the latest release",
            "matchManagers": ["github-actions"],
            "pinDigests": true,
            "addLabels": ["github-actions"]
        },
        {
            "description": "Group all git submodule (repos/frida-*) bumps into one PR",
            "matchManagers": ["git-submodules"],
            "groupName": "git submodules",
            "addLabels": ["git-submodule"]
        },
        {
            "description": "Keep the Nix flake inputs (flake.lock) current",
            "matchManagers": ["nix"],
            "addLabels": ["nix"]
        }
    ]
}
